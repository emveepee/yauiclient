#!/usr/bin/make -f
# debian-legacy/rules - X11-only Debian 11 build of yauiclient
#
# Single binary package, X11 + bundled libmpv (built on Debian 11 for
# glibc 2.31 compatibility). For Debian 12+/Ubuntu 24.04+ targets see
# the parallel debian/ tree.

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# Tell the linker where to find libmpv's siblings (FFmpeg 7, libplacebo 351,
# etc.) when resolving libmpv.so's NEEDED entries at link time. The .so files
# are present in $(SDK_DIR)/lib but ld doesn't search there automatically.
# -Wl,-rpath-link is the right knob: it adds the dir to the LINK-TIME
# resolution path WITHOUT baking it into the binary's rpath. The rpath
# itself stays $ORIGIN/../lib/yauiclient/lib (set by CMakeLists.txt under
# YAUI_DEB_LAYOUT=ON), pointing at the bundled libs we install.
#
# --disable-new-dtags forces the linker to emit DT_RPATH instead of
# DT_RUNPATH. The difference matters at runtime: DT_RPATH lookups apply
# to BOTH the binary AND its NEEDED libraries (so libmpv can find its
# own NEEDED libs like libavcodec.so.61 via yauiclient's rpath), while
# DT_RUNPATH only applies to the binary itself - libmpv would then need
# its own rpath to find its siblings, which our prebuilt libmpv doesn't
# have, leading to "cannot open shared object" errors at startup.
export DEB_LDFLAGS_MAINT_APPEND = -L$(CURDIR)/sdk/lib -Wl,-rpath-link=$(CURDIR)/sdk/lib -Wl,--disable-new-dtags

include /usr/share/dpkg/architecture.mk
include /usr/share/dpkg/buildflags.mk

PKG_NAME    = yauiclient-x11-legacy
SDK_DIR     = $(CURDIR)/sdk
BUNDLE_DIR  = debian/$(PKG_NAME)/usr/lib/yauiclient/lib

# Bundled-flavour libraries to copy from sdk/lib/. Kept loose with .so*
# globs so this same logic works regardless of FFmpeg/libplacebo SONAME
# changes between mpv tag bumps. Each pattern must match at least one
# file or the install step fails loudly.
BUNDLE_PATTERNS = libmpv.so libmpv.so.* \
                  libavcodec.so.* libavformat.so.* libavutil.so.* \
                  libavfilter.so.* libswresample.so.* libswscale.so.* \
                  libplacebo.so.*

# Optional libraries that may or may not be in the runtime tarball.
# Patterns that don't match are silently skipped (no error). This is for
# things like libluajit which is sometimes bundled, sometimes not, and
# things the Debian 12 build adds (libdav1d.so.6, libdisplay-info.so.2,
# libjpeg.so.62) that the Debian 11 build doesn't ship.
BUNDLE_PATTERNS_OPTIONAL = libluajit-5.1.so.* \
                           libdav1d.so.* \
                           libdisplay-info.so.* \
                           libjpeg.so.*

%:
	dh $@ --buildsystem=cmake+ninja --builddirectory=build/legacy

override_dh_auto_configure:
	dh_auto_configure -- \
	  -DCMAKE_BUILD_TYPE=Release \
	  -DYAUI_WAYLAND=OFF \
	  -DYAUI_DEB_LAYOUT=ON \
	  -DLIBMPV_SDK_DIR=$(SDK_DIR) \
	  -DYAUICLIENT_USE_SYSTEM_MPV=OFF

# yauiclient has no test suite. Without this override, dh_auto_test would
# call 'ninja test', which fails with 'unknown target' on a CMakeLists that
# doesn't declare any tests via add_test() / enable_testing().
override_dh_auto_test:

override_dh_auto_install:
	dh_auto_install
	# Bundle the libmpv runtime alongside the binary
	mkdir -p $(BUNDLE_DIR)
	# Required patterns - fail if any pattern matches nothing
	set -e; \
	for pat in $(BUNDLE_PATTERNS); do \
	    found=0; \
	    for f in $(SDK_DIR)/lib/$$pat; do \
	        if [ -e "$$f" ] || [ -L "$$f" ]; then \
	            cp -P "$$f" $(BUNDLE_DIR)/; \
	            found=1; \
	        fi; \
	    done; \
	    if [ $$found -eq 0 ]; then \
	        echo "ERROR: no files matched required pattern '$$pat' in $(SDK_DIR)/lib/"; \
	        exit 1; \
	    fi; \
	done
	# Optional patterns - silently skip if absent
	for pat in $(BUNDLE_PATTERNS_OPTIONAL); do \
	    for f in $(SDK_DIR)/lib/$$pat; do \
	        if [ -e "$$f" ] || [ -L "$$f" ]; then \
	            cp -P "$$f" $(BUNDLE_DIR)/; \
	        fi; \
	    done; \
	done
	# Bundle libfmt.so.7 and libjpeg.so.62 from the build host. yauiclient
	# links libfmt directly (so its SONAME 'libfmt.so.7' must be available
	# on every target distro); bundled libmpv links libjpeg.so.62. Neither
	# SONAME is consistently named in apt across Debian family distros
	# (libfmt is .7 on bullseye, .8 on jammy, .9 on bookworm; libjpeg-turbo
	# is .62 on Debian, .8 on Ubuntu's libjpeg-turbo8 package). Bundling
	# fixes this once, here.
	set -e; \
	for pat in libfmt.so.7 libfmt.so.7.* \
	           libjpeg.so.62 libjpeg.so.62.*; do \
	    found=0; \
	    for f in /usr/lib/x86_64-linux-gnu/$$pat /usr/lib/$$pat; do \
	        if [ -e "$$f" ] || [ -L "$$f" ]; then \
	            cp -P "$$f" $(BUNDLE_DIR)/; \
	            found=1; \
	        fi; \
	    done; \
	    if [ $$found -eq 0 ]; then \
	        echo "ERROR: no system file matched '$$pat' in /usr/lib/x86_64-linux-gnu/"; \
	        echo "       libfmt-dev / libjpeg62-turbo-dev should be installed"; \
	        exit 1; \
	    fi; \
	done
	# Install the desktop entry. Uses 'yauiclient' StartupWMClass since
	# this is X11 only (no Wayland app_id matching).
	install -D -m 0644 debian/yauiclient-x11-legacy.desktop \
	  debian/$(PKG_NAME)/usr/share/applications/yauiclient.desktop

override_dh_shlibdeps:
	# -xlibfmt7 tells dpkg-shlibdeps to exclude libfmt7 from the auto-
	# generated Depends. yauiclient links libfmt.so.7 dynamically, but
	# we bundle our own copy in /usr/lib/yauiclient/lib/, so we don't
	# want apt to require the system libfmt7 package (which only exists
	# on Debian 11; newer distros have libfmt8/9/etc).
	dh_shlibdeps -l$(CURDIR)/$(BUNDLE_DIR) -- --ignore-missing-info -xlibfmt7

override_dh_dwz:
	dh_dwz -X /usr/lib/yauiclient/lib/

override_dh_strip:
	dh_strip --no-automatic-dbgsym
